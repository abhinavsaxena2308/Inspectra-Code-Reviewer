# Backend Server Port (Default: 5000)
PORT=5000

# Environment (development, production, test)
NODE_ENV=development

# GitHub Personal Access Token - Required for API requests
GITHUB_TOKEN=

# Google Gemini API Key - Required for AI functionalities
GEMINI_API_KEY=your_gemini_api_key_here

# Clerk Publishable Key - Required for Frontend Authentication
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: Disable Vite Hot Module Replacement (HMR)
# DISABLE_HMR=true
